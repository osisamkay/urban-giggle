{
  "info": {
    "name": "ShareStake Production API",
    "description": "Full API collection for the ShareStake Marketplace. Includes all secure endpoints and hardened logic.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Sign Up",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"SecurePass123!\",\n  \"role\": \"BUYER\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/auth/signup" }
          }
        },
        {
          "name": "Sign In",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"SecurePass123!\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/auth/signin" }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/auth/me" }
          }
        }
      ]
    },
    {
      "name": "Products & Sellers",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/products" }
          }
        },
        {
          "name": "Update Product (Seller Only)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"product-uuid-here\",\n  \"updates\": {\n    \"price\": 45.99,\n    \"inventory\": 100\n  }\n}"
            },
            "url": { "raw": "{{base_url}}/api/products/update" }
          }
        }
      ]
    },
    {
      "name": "Orders & Payments",
      "item": [
        {
          "name": "Create Order (Hardened)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"seller_id\": \"seller-uuid\",\n  \"items\": [\n    { \"product_id\": \"prod-1\", \"quantity\": 2, \"price_at_purchase\": 50.00 }\n  ],\n  \"shipping_address_id\": \"addr-uuid\",\n  \"subtotal\": 100.00,\n  \"tax\": 10.00,\n  \"shipping\": 5.00,\n  \"total\": 115.00\n}"
            },
            "url": { "raw": "{{base_url}}/api/create-order" }
          }
        },
        {
          "name": "Update Payment Intent",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"order_id\": \"order-uuid\",\n  \"payment_intent_id\": \"pi_stripe_123\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/orders/payment-update" }
          }
        }
      ]
    },
    {
      "name": "Group Buying",
      "item": [
        {
          "name": "Join Group",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"groupId\": \"group-uuid\",\n  \"quantity\": 5\n}"
            },
            "url": { "raw": "{{base_url}}/api/groups/join" }
          }
        },
        {
          "name": "Leave Group",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/groups/leave?groupId=group-uuid" }
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Create Review (Verified)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"prod-uuid\",\n  \"rating\": 5,\n  \"title\": \"Amazing quality!\",\n  \"comment\": \"The best steak I have ever had.\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/reviews/create" }
          }
        },
        {
          "name": "Delete Review",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/reviews/delete?id=review-uuid" }
          }
        }
      ]
    },
    {
      "name": "Messaging",
      "item": [
        {
          "name": "Get Messages",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/messages/get?conversationId=conv-uuid" }
          }
        },
        {
          "name": "Send Message",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"conversationId\": \"conv-uuid\",\n  \"content\": \"Hello! Is this still available?\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/messages/send" }
          }
        }
      ]
    },
    {
      "name": "System Maintenance",
      "item": [
        {
          "name": "The Reaper (Clean Pending Orders)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/cron/cleanup-orders?secret={{cron_secret}}" }
          }
        }
      ]
    }
  ],
  "event": [],
  "variable": [
    { "key": "base_url", "value": "http://localhost:3500", "type": "string" },
    { "key": "token", "value": "your_jwt_token_here", "type": "string" },
    { "key": "cron_secret", "value": "your_cron_secret_here", "type": "string" }
  ]
}
